            owl:onProperty nfdi:has_quantitative_attribute ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nfdi:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/was_generated_by> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/Activity> ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/was_generated_by> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi:has_quantitative_attribute ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/other_identifier> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/has_part> ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi:QualitativeAttribute ;
            owl:onProperty nfdi:has_qualitative_attribute ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/has_part> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty nfdi:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/description> ],
        nfdi:ClassifierMixin ;
    skos:definition "Something (not an activity or process) that is being evaluated in a DataCreatingActivity." ;
    skos:exactMatch prov:Entity ;
    skos:inScheme nfdi: .

