nfdi:Environment a owl:Class ;
    rdfs:label "Environment" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/title> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/title> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/other_identifier> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/title> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/Identifier> ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/other_identifier> ],
        nfdi:ClassifierMixin ;
    skos:definition "The surrounding in which the dataset creating activity took place (e.g. a lab)." ;
    skos:exactMatch prov:Entity ;
    skos:inScheme nfdi: .

nfdi:from_CV a owl:DatatypeProperty ;
    rdfs:label "from_CV" ;
    skos:definition "The URL of the controlled vocabulary." ;
    skos:inScheme nfdi: .

nfdi:has_quantity_type a owl:ObjectProperty ;
    rdfs:label "has_quantity_type" ;
    skos:definition "The type of quality that is quantifiable according to the QUDT ontology." ;
    skos:inScheme nfdi: .

nfdi:occurred_in a owl:ObjectProperty ;
    rdfs:label "occurred_in" ;
    rdfs:range nfdi:Environment ;
    skos:definition "The slot to specify the Method (aka Procedure) that was used in the DataCreatingActivity." ;
    skos:inScheme nfdi: .

nfdi:rdf_type a owl:ObjectProperty ;
    rdfs:label "rdf_type" ;
    rdfs:range nfdi:DefinedTerm ;
    skos:definition "The slot to specify the ontology class that is instantiated by an entity." ;
    skos:inScheme nfdi: .

nfdi:realized_plan a owl:ObjectProperty ;
    rdfs:label "realized_plan" ;
    rdfs:range nfdi:Plan ;
    skos:definition "The slot to specify the Method (aka Procedure) that was realized by a DataCreatingActivity." ;
    skos:inScheme nfdi: .

nfdi:unit a owl:ObjectProperty ;
    rdfs:label "unit" ;
    skos:inScheme nfdi: .

