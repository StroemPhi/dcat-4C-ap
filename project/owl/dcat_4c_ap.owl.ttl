xsd:duration a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "-?P((([0-9]+Y([0-9]+M)?([0-9]+D)?|([0-9]+M)([0-9]+D)?|([0-9]+D))(T(([0-9]+H)([0-9]+M)?([0-9]+(\\.[0-9]+)?S)?|([0-9]+M)([0-9]+(\\.[0-9]+)?S)?|([0-9]+(\\.[0-9]+)?S)))?)|(T(([0-9]+H)([0-9]+M)?([0-9]+(\\.[0-9]+)?S)?|([0-9]+M)([0-9]+(\\.[0-9]+)?S)?|([0-9]+(\\.[0-9]+)?S))))" ] ) ] .

nfdi4c:ChemicalSample a owl:Class ;
    rdfs:label "ChemicalSample" ;
    rdfs:subClassOf nfdi4c:ChemicalSubstance ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_4c_ap> .

nfdi4c:composed_of a owl:ObjectProperty ;
    rdfs:label "composed_of" ;
    skos:definition "The slot to provide the chemical entities of which the chemical substance is composed of." ;
    skos:exactMatch BFO:0000051 ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_4c_ap> .

nfdi:AnalysedData a owl:Class ;
    rdfs:label "AnalysedData" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nfdi4c:was_generated_by ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi:DataCreatingActivity ;
            owl:onProperty nfdi4c:was_generated_by ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi4c:was_generated_by ],
        nfdi:EvaluatedEntity ;
    skos:definition "Information that was evaluated within an Analysis." ;
    skos:exactMatch prov:Entity ;
    skos:inScheme nfdi: .

nfdi:DataAnalysis a owl:Class ;
    rdfs:label "DataAnalysis" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nfdi:AnalysedData ;
            owl:onProperty nfdi4c:evaluated_entity ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi4c:evaluated_entity ],
        nfdi:DataCreatingActivity ;
    skos:closeMatch NCIT:C25391 ;
    skos:definition "A DataCreatingActivity that evaluates the data produced by another DataCreatingActivity." ;
    skos:exactMatch OBI:0200000,
        prov:Activity ;
    skos:inScheme nfdi: .

nfdi:Plan a owl:Class ;
    rdfs:label "Plan" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/title> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/title> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/title> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/description> ],
        nfdi:ClassifierMixin ;
    skos:altLabel "Method",
        "Plan Specification",
        "Procedure" ;
    skos:definition """A piece of information that specifies: a) how an activity has to be carried out by its agents including what 
kind of steps have to be taken and what kind of parameters have to be met/set.""" ;
    skos:exactMatch prov:Entity ;
    skos:inScheme nfdi: .

nfdi:ResearchDataset a owl:Class ;
    rdfs:label "ResearchDataset" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nfdi:DataCreatingActivity ;
            owl:onProperty nfdi4c:was_generated_by ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi:describes_activity ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty nfdi4c:was_generated_by ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nfdi:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty nfdi:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi:describes_entity ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi:EvaluatedActivity ;
            owl:onProperty nfdi:describes_activity ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty nfdi:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi:EvaluatedEntity ;
            owl:onProperty nfdi:describes_entity ],
        <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/Dataset> ;
    skos:definition "A collection of data, published or curated by a single agent, and available for access or download in one or more representations." ;
    skos:exactMatch dcat:Dataset ;
    skos:inScheme nfdi: ;
    skos:note "The name of this class is only deviating from its parent as this is needed according to the sublcassing strategy chosen here in this LinkML model to further constrain the slots of existing (imported) classes." .

nfdi:describes_activity a owl:ObjectProperty ;
    rdfs:label "describes_activity" ;
    rdfs:range nfdi:EvaluatedActivity ;
    skos:definition "A slot to provide the EvaluatedActivity that is described by a Dataset." ;
    skos:inScheme nfdi: .

nfdi:describes_entity a owl:ObjectProperty ;
    rdfs:label "describes_entity" ;
    rdfs:range nfdi:EvaluatedEntity ;
    skos:definition "A slot to provide the EvaluatedEntity that is described by a Dataset." ;
    skos:inScheme nfdi: .

nfdi:evaluated_activity a owl:ObjectProperty ;
    rdfs:label "evaluated_activity" ;
    rdfs:range nfdi:EvaluatedActivity ;
    skos:definition "The slot to specify the activity of interest that was evaluated." ;
    skos:inScheme nfdi: .

nfdi:evaluated_entity a owl:ObjectProperty ;
    rdfs:label "evaluated_entity" ;
    rdfs:range nfdi:EvaluatedEntity ;
    skos:definition "The slot to specify the entity of interest that was evaluated." ;
    skos:inScheme nfdi: .

nfdi:used_tool a owl:ObjectProperty ;
    rdfs:label "used_tool" ;
    rdfs:range nfdi:Tool ;
    skos:definition "The slot to specify the tool that was used." ;
    skos:inScheme nfdi: .

