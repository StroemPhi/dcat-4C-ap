@prefix BFO: <http://purl.obolibrary.org/obo/BFO_> .
@prefix CHEBI: <http://purl.obolibrary.org/obo/CHEBI_> .
@prefix CHEMINF: <http://semanticscience.org/resource/CHEMINF_> .
@prefix CHMO: <http://purl.obolibrary.org/obo/CHMO_> .
@prefix NCIT: <http://purl.obolibrary.org/obo/NCIT_> .
@prefix NMR: <http://nmrML.org/nmrCV#NMR:> .
@prefix OBI: <http://purl.obolibrary.org/obo/OBI_> .
@prefix RXNO: <http://purl.obolibrary.org/obo/RXNO_> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix nfdi: <https://stroemphi.github.io/dcat-4C-ap/dcat_4nfdi_ap/> .
@prefix nfdi4c: <https://stroemphi.github.io/dcat-4C-ap/dcat_4c_ap/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://stroemphi.github.io/dcat-4C-ap/dcat_4c_ap.owl.ttl> a owl:Ontology ;
    rdfs:label "dcat-4C-ap" ;
    dcterms:license "CC-BY 4.0" ;
    dcterms:title "DCAT-4C-AP" ;
    rdfs:seeAlso <https://StroemPhi.github.io/dcat-NFDI-ap>,
        <https://github.com/HendrikBorgelt/DCAT-ap_as_LinkML_template/blob/main/src/dcatlinkml/schema/dcatlinkml.yaml>,
        <https://gitlab.com/opensourcelab/scientificdata/scidats/-/blob/feature/linkml-schemata/schemata/metadata_model_scidats_dcat_ap.yaml?ref_type=heads> ;
    skos:definition "This is an extension of the DCAT Application Profile in LinkML. It is intended to be used by NFDI4Chem & NFDI 4Cat as a core that can further be extended in profiles to provide domain specific metadata for a dataset." .

nfdi4c:ChemicalReaction a owl:Class ;
    rdfs:label "ChemicalReaction" ;
    rdfs:subClassOf nfdi:EvaluatedActivity ;
    skos:definition "An experimental procedure with the aim of producing a portion of a given compound or mixture." ;
    skos:exactMatch RXNO:0000329 ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_4c_ap> .

nfdi4c:Laboratory a owl:Class ;
    rdfs:label "Laboratory" ;
    rdfs:subClassOf nfdi:Environment ;
    skos:definition "A facility that provides controlled conditions in which scientific or technological research, experiments, and measurement may be performed." ;
    skos:exactMatch prov:Entity ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_4c_ap> .

nfdi4c:NMRAnalysisDataset a owl:Class ;
    rdfs:label "NMRAnalysisDataset" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nfdi4c:ChemicalSample ;
            owl:onProperty nfdi4c:describes_entity ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi4c:describes_entity ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi4c:NMRSpectralAnalysis ;
            owl:onProperty nfdi4c:was_generated_by ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi4c:was_generated_by ],
        nfdi:AnalysisDataset ;
    skos:definition "A dataset that is the result of a NMRSpectralAnalysis of a ChemicalSample." ;
    skos:exactMatch dcat:Dataset ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_4c_ap> ;
    skos:note "This class serves as an example for the way in which we want to build domain specific schema profiles. It will be outsourced to a more appropriate location in the future." .

nfdi4c:QUDTQuantityKindEnum a owl:Class .

nfdi4c:QUDTUnitEnum a owl:Class .

nfdi:HardwareTool a owl:Class ;
    rdfs:label "HardwareTool" ;
    rdfs:subClassOf nfdi:Tool ;
    skos:altLabel "Device" ;
    skos:definition "A hardware device with a certain function that was used within a DataCreatingActivity." ;
    skos:inScheme nfdi: .

nfdi:ResearchCatalog a owl:Class ;
    rdfs:label "ResearchCatalog" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty nfdi:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi:ResearchDataset ;
            owl:onProperty nfdi4c:has_dataset ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nfdi4c:has_dataset ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nfdi:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty nfdi:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi4c:has_dataset ],
        <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/Catalogue> ;
    skos:definition "A curated collection of metadata about data resources." ;
    skos:exactMatch dcat:Catalog ;
    skos:inScheme nfdi: ;
    skos:note "The name of this class is only deviating from its parent as this is needed according to the sublcassing strategy chosen here in this LinkML model to further constrain the slots of existing (imported) classes." .

nfdi:SoftwareTool a owl:Class ;
    rdfs:label "SoftwareTool" ;
    rdfs:subClassOf nfdi:Tool ;
    skos:definition "A software device with a certain function that was used within a DataCreatingActivity." ;
    skos:inScheme nfdi: .

CHMO:0000595 a owl:Class ;
    rdfs:label "CHMO:0000595" ;
    rdfs:subClassOf nfdi4c:NMRAssayEnum .

xsd:hexBinary a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "([0-9a-fA-F]{2})*" ] ) ] .

xsd:nonNegativeInteger a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "([\\-+]?[0-9]+)" ] ) ] .

nfdi4c:ChemicalEntity a owl:Class ;
    rdfs:label "ChemicalEntity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nfdi4c:InChIKey ;
            owl:onProperty nfdi4c:inchikey ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nfdi4c:iupac_formula ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi4c:iupac_formula ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nfdi4c:inchikey ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nfdi4c:smiles ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi4c:InChi ;
            owl:onProperty nfdi4c:inchi ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi4c:SMILES ;
            owl:onProperty nfdi4c:smiles ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi4c:inchikey ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi4c:smiles ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi4c:IUPACChemicalFormula ;
            owl:onProperty nfdi4c:iupac_formula ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi4c:inchi ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nfdi4c:inchi ] ;
    skos:definition "Any constitutionally or isotopically distinct atom, molecule, ion, ion pair, radical, radical ion, complex, conformer etc., identifiable as a separately distinguishable entity." ;
    skos:exactMatch CHEBI:23367 ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_4c_ap> .

nfdi4c:ChemicalSubstance a owl:Class ;
    rdfs:label "ChemicalSubstance" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nfdi4c:has_role ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nfdi4c:has_role ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi4c:has_role ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi4c:composed_of ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi4c:ChemicalEntity ;
            owl:onProperty nfdi4c:composed_of ],
        nfdi:EvaluatedEntity ;
    skos:definition "A portion of matter of constant composition, composed of molecular entities of the same type or of different types that is being evaluated in a scientific process." ;
    skos:exactMatch prov:Entity ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_4c_ap> .

nfdi4c:IUPACChemicalFormula a owl:Class ;
    rdfs:label "IUPACChemicalFormula" ;
    rdfs:subClassOf nfdi:QualitativeAttribute ;
    skos:definition "A systematic name which is formulated according to the rules and recommendations for chemical nomenclature set out by the International Union of Pure and Applied Chemistry (IUPAC)." ;
    skos:exactMatch CHEMINF:000037 ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_4c_ap> .

nfdi4c:InChIKey a owl:Class ;
    rdfs:label "InChIKey" ;
    rdfs:subClassOf nfdi:QualitativeAttribute ;
    skos:exactMatch CHEMINF:000059 ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_4c_ap> .

nfdi4c:InChi a owl:Class ;
    rdfs:label "InChi" ;
    rdfs:subClassOf nfdi:QualitativeAttribute ;
    skos:definition "A structure descriptor which conforms to the InChI format specification." ;
    skos:exactMatch CHEMINF:000113 ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_4c_ap> .

nfdi4c:NMRAssayEnum a owl:Class ;
    linkml:permissible_values CHMO:0000595 .

nfdi4c:NMRSpectralAnalysis a owl:Class ;
    rdfs:label "NMRSpectralAnalysis" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi4c:evaluated_entity ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi4c:NMRSpectrum ;
            owl:onProperty nfdi4c:evaluated_entity ],
        nfdi:DataAnalysis ;
    skos:definition "A DataAnalysis which assigns a chemical structure to the peaks of a NMRSpectrum generated by a NMRSpectroscopy" ;
    skos:exactMatch NMR:1000259 ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_4c_ap> ;
    skos:note "This class serves as an example for the way in which we want to build domain specific schema profiles. It will be outsourced to a more appropriate location in the future." .

nfdi4c:NMRSpectroscopy a owl:Class ;
    rdfs:label "NMRSpectroscopy" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty nfdi4c:rdf_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi4c:evaluated_entity ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi4c:ChemicalSample ;
            owl:onProperty nfdi4c:evaluated_entity ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi4c:rdf_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nfdi4c:rdf_type ],
        nfdi:DataCreatingActivity ;
    skos:definition "Spectroscopy where the energy states of spin-active nuclei placed in a static magnetic field are interrogated by inducing transitions between the states via radio frequency irradiation. Each experiment consists of a sequence of radio frequency pulses with delay periods in between them." ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_4c_ap> ;
    skos:note "This class serves as an example for the way in which we want to build domain specific schema profiles. It will be outsourced to a more appropriate location in the future." .

nfdi4c:NMRSpectrum a owl:Class ;
    rdfs:label "NMRSpectrum" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi4c:was_generated_by ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi4c:NMRSpectroscopy ;
            owl:onProperty nfdi4c:was_generated_by ],
        nfdi:AnalysedData ;
    skos:definition "A set of chemical shifts obtained via NMR spectroscopy." ;
    skos:exactMatch NMR:1002007 ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_4c_ap> ;
    skos:note "This class serves as an example for the way in which we want to build domain specific schema profiles. It will be outsourced to a more appropriate location in the future." .

nfdi4c:SMILES a owl:Class ;
    rdfs:label "SMILES" ;
    rdfs:subClassOf nfdi:QualitativeAttribute ;
    skos:definition "A structure descriptor that denotes a molecular structure as a graph and conforms to the SMILES format specification." ;
    skos:exactMatch CHEMINF:000018 ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_4c_ap> .

nfdi:AnalysisDataset a owl:Class ;
    rdfs:label "AnalysisDataset" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nfdi4c:was_generated_by ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi:DataAnalysis ;
            owl:onProperty nfdi4c:was_generated_by ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi4c:was_generated_by ],
        nfdi:ResearchDataset ;
    skos:exactMatch dcat:Dataset ;
    skos:inScheme nfdi: .

<https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/Attribution> a owl:Class ;
    rdfs:label "Attribution" ;
    rdfs:subClassOf <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/SupportiveEntity> ;
    skos:definition "See [DCAT-AP specs:Attribution](https://semiceu.github.io/DCAT-AP/releases/3.0.0/#Attribution)" ;
    skos:exactMatch prov:Attribution ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml> .

<https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/CataloguedResource> a owl:Class ;
    rdfs:label "CataloguedResource" ;
    skos:definition "See [DCAT-AP specs:CataloguedResource](https://semiceu.github.io/DCAT-AP/releases/3.0.0/#CataloguedResource)" ;
    skos:exactMatch dcat:Resource ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml> .

<https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/Checksum> a owl:Class ;
    rdfs:label "Checksum" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:hexBinary ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/checksum_value> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/algorithm> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/algorithm> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/checksum_value> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/ChecksumAlgorithm> ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/algorithm> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/checksum_value> ],
        <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/SupportiveEntity> ;
    skos:definition "See [DCAT-AP specs:Checksum](https://semiceu.github.io/DCAT-AP/releases/3.0.0/#Checksum)" ;
    skos:exactMatch <http://spdx.org/rdf/terms#Checksum> ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml> .

<https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/ChecksumAlgorithm> a owl:Class ;
    rdfs:label "ChecksumAlgorithm" ;
    rdfs:subClassOf <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/SupportiveEntity> ;
    skos:definition "See [DCAT-AP specs:ChecksumAlgorithm](https://semiceu.github.io/DCAT-AP/releases/3.0.0/#ChecksumAlgorithm)" ;
    skos:exactMatch <http://spdx.org/rdf/terms#ChecksumAlgorithm> ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml> .

<https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/ConceptScheme> a owl:Class ;
    rdfs:label "ConceptScheme" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/title> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/title> ],
        <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/SupportiveEntity> ;
    skos:definition "See [DCAT-AP specs:ConceptScheme](https://semiceu.github.io/DCAT-AP/releases/3.0.0/#ConceptScheme)" ;
    skos:exactMatch skos:ConceptScheme ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml> .

<https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/DatasetSeries> a owl:Class ;
    rdfs:label "DatasetSeries" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/publisher> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/frequency> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/frequency> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/release_date> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/Agent> ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/publisher> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/applicable_legislation> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/Kind> ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/contact_point> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/Location> ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/geographical_coverage> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/modification_date> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/modification_date> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/temporal_coverage> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/geographical_coverage> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/publisher> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/title> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/Frequency> ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/frequency> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/release_date> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/LegalResource> ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/applicable_legislation> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/release_date> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/title> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/contact_point> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/PeriodOfTime> ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/temporal_coverage> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/modification_date> ] ;
    skos:definition "See [DCAT-AP specs:DatasetSeries](https://semiceu.github.io/DCAT-AP/releases/3.0.0/#DatasetSeries)" ;
    skos:exactMatch dcat:DatasetSeries ;
    skos:inScheme <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml> .

