            owl:onProperty nfdi:used_tool ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nfdi:occurred_in ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nfdi:realized_plan ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/title> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/Activity> ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/has_part> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi:occurred_in ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/title> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/has_part> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi:Plan ;
            owl:onProperty nfdi:realized_plan ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi:evaluated_entity ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi:Tool ;
            owl:onProperty nfdi:used_tool ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/other_identifier> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/has_part> ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi:EvaluatedEntity ;
            owl:onProperty nfdi:evaluated_entity ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/Identifier> ;
            owl:onProperty <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/other_identifier> ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi:EvaluatedActivity ;
            owl:onProperty nfdi:evaluated_activity ],
        [ a owl:Restriction ;
            owl:allValuesFrom nfdi:Environment ;
            owl:onProperty nfdi:occurred_in ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nfdi:realized_plan ],
        nfdi:ClassifierMixin,
        <https://stroemphi.github.io/dcat-4C-ap/dcat_ap_linkml/Activity> ;
    skos:definition "An activity (process) that has the objective to produce information about an entity by evaluating it." ;
    skos:exactMatch prov:Activity ;
